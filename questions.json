        {"id": "q14", "question": "Un même produit peut répondre à plusieurs besoins différents.", "options": [{"texte": "Vrai", "correct": true}, {"texte": "Faux", "correct": false}, {"texte": "Faux, un seul besoin par produit", "correct": false}, {"texte": "Seulement les produits complexes", "correct": false}]},
