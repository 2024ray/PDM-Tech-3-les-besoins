        {"id": "q8", "question": "La valeur d'usage est l'aptitude du produit à satisfaire le besoin.", "options": [{"texte": "Vrai", "correct": true}, {"texte": "Faux", "correct": false}, {"texte": "Faux, c'est l'estime", "correct": false}, {"texte": "Partiellement vrai", "correct": false}]},
